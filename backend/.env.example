# Datastraw Support CRM — Backend Configuration

# Database URL
# For local development (SQLite):
DATABASE_URL=sqlite:///./crm.db

# For production with PostgreSQL (Vercel/Railway/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Example: DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-1.aws.neon.tech/neondb

# CORS origins (comma-separated for production)
# Development: http://localhost:5173
# Production: https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173

# Server configuration
HOST=0.0.0.0
PORT=8000